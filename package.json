{
  "name": "cos30043-apple-storefront",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web \"npm run api\" \"wait-on -t 30000 http://localhost:3001/api/products && vite --host 0.0.0.0\"",
    "dev:web": "vite --host 0.0.0.0",
    "api": "node server/server.js",
    "start": "npm run dev",
    "build": "vite build && node scripts/package-mercury.mjs",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "latest",
    "bcryptjs": "^3.0.3",
    "bootstrap": "latest",
    "concurrently": "latest",
    "cors": "latest",
    "dotenv": "^17.4.2",
    "express": "latest",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "nodemailer": "^8.0.8",
    "vite": "latest",
    "vue": "latest",
    "vue-router": "latest"
  },
  "devDependencies": {
    "wait-on": "^9.0.10"
  }
}
