  },
  "dependencies": {
    "@vitejs/plugin-vue": "latest",
    "bootstrap": "latest",
    "concurrently": "latest",
    "cors": "latest",
    "dotenv": "^17.4.2",
    "express": "latest",
    "mongodb": "^7.2.0",
    "nodemailer": "^8.0.8",
    "vite": "latest",
    "vue": "latest",
    "vue-router": "latest"
  },
  "devDependencies": {
    "wait-on": "^9.0.10"
  }
}
