# Used by npm run dev (Node API) and npm run build (Mercury PHP API config)
MONGODB_URI=mongodb+srv://...
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
PORT=3001

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
DISCOUNT_FROM_EMAIL=NovaTech Store <your@gmail.com>
